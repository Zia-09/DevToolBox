# DevToolbox Environment Variables
# All are optional - the app works fully without any of them set.

# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Plausible Analytics Domain (e.g., devtoolbox.io)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google AdSense Publisher ID (e.g., pub-xxxxxxxxxxxxxxxx)
NEXT_PUBLIC_ADSENSE_ID=

# Site URL - used for sitemap, canonical URLs, and metadata
NEXT_PUBLIC_SITE_URL=https://devtoolbox.io
